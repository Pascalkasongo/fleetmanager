{% extends 'base.html.twig' %}

{% block title %}Suivi{% endblock %}

{% block body %}
    <h1>Suivi</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ suivi.id }}</td>
            </tr>
            <tr>
                <th>Kilometrage_actuel</th>
                <td>{{ suivi.kilometrageActuel }}</td>
            </tr>
            <tr>
                <th>Date</th>
                <td>{{ suivi.date ? suivi.date|date('Y-m-d') : '' }}</td>
            </tr>
            <tr>
                <th>Ecart</th>
                <td>{{ suivi.ecart }}</td>
            </tr>
            <tr>
                <th>Statut</th>
                <td>{{ suivi.statut }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_suivi_index') }}">back to list</a>

    <a href="{{ path('app_suivi_edit', {'id': suivi.id}) }}">edit</a>

    {{ include('suivi/_delete_form.html.twig') }}
{% endblock %}
