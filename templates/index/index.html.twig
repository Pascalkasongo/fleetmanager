{% include 'index/header.html.twig' %}
  <!-- Hero -->
  <section class="max-w-6xl mx-auto px-4 py-16 text-center">
    <h2 class="text-4xl font-bold mb-4">
      Bienvenue sur ton Dashboard
    </h2>

    <p class="text-gray-600 mb-6">
      Une interface moderne construite avec Tailwind CSS, rapide et responsive.
    </p>

    <button class="bg-primary text-white px-6 py-3 rounded-lg shadow hover:bg-indigo-600 transition">
      Commencer
    </button>
  </section>

  <!-- Cards -->
  <section class="max-w-6xl mx-auto px-4 grid md:grid-cols-3 gap-6">

    <div class="bg-white p-6 rounded-xl shadow hover:shadow-lg transition">
      <h3 class="font-bold text-lg mb-2">Flotte</h3>
      <p class="text-gray-600">Gerer efficacement la flotte</p>
