<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard Tailwind</title>

  <!-- Tailwind CDN (simple pour test / dev) -->
  <script src="https://cdn.tailwindcss.com"></script>

  <!-- Option: config Tailwind -->
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            primary: '#4f46e5'
          }
        }
      }
    }
  </script>
</head>

<body class="bg-gray-100 text-gray-800">

  <!-- Navbar -->
  <header class="bg-white shadow">
    <div class="max-w-6xl mx-auto px-4 py-4 flex justify-between items-center">
      <h1 class="text-xl font-bold text-primary">Fleet manager</h1>

      <nav class="space-x-6 hidden md:block relative">

  <a href="{{ path('app_index') }}" class="hover:text-primary">Accueil</a>

  <!-- Dropdown Flottes -->
  <div class="inline-block relative group">

    <button class="hover:text-primary flex items-center gap-1">
      Flottes
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M19 9l-7 7-7-7" />
      </svg>
    </button>

    <!-- Sous-menu -->
    <div class="absolute left-0 mt-2 w-48 bg-white border rounded-lg shadow-lg
                opacity-0 invisible group-hover:opacity-100 group-hover:visible
                transition-all duration-200 z-50">

      <a href="{{ path('app_suivi_index') }}" class="block px-4 py-2 hover:bg-gray-100">
        Suivi des flottes
      </a>

      <a href="{{ path('app_chauffeur_index') }}" class="block px-4 py-2 hover:bg-gray-100">
        Chauffeur
      </a>

      <a href="{{ path('app_vehicule_index') }}"
        class="block px-4 py-2 hover:bg-gray-100">
          Véhicules
      </a>

      <a href="{{ path('app_maintenance_index') }}" class="block px-4 py-2 hover:bg-gray-100">
        Maintenance
      </a>

    </div>
  </div>

  <a href="#" class="hover:text-primary">Dashboard</a>
  <a href="{{ path('app_affectation_index') }}" class="hover:text-primary">Affectation</a>

</nav>

      <button class="md:hidden px-3 py-2 border rounded">
        ☰
      </button>
    </div>
  </header>
  <div id="toast-container" class="fixed top-5 right-5 z-50 space-y-3">

    {% for message in app.flashes('success') %}
        <div class="toast flex items-start gap-3 max-w-sm rounded-xl border border-green-200 bg-white p-4 shadow-lg transition-all duration-300">
            <div class="flex h-10 w-10 items-center justify-center rounded-full bg-green-100 text-green-600">
                ✓
            </div>

            <div class="flex-1">
                <h3 class="font-semibold text-green-700">Succès</h3>
                <p class="text-sm text-gray-600">
                    {{ message }}
                </p>
            </div>

            <button class="close-toast text-gray-400 hover:text-gray-600">
                ✕
            </button>
        </div>
    {% endfor %}

    {% for message in app.flashes('error') %}
        <div class="toast flex items-start gap-3 max-w-sm rounded-xl border border-red-200 bg-white p-4 shadow-lg transition-all duration-300">
            <div class="flex h-10 w-10 items-center justify-center rounded-full bg-red-100 text-red-600">
                ⚠
            </div>

            <div class="flex-1">
                <h3 class="font-semibold text-red-700">Attention</h3>
                <p class="text-sm text-gray-600">
                    {{ message }}
                </p>
            </div>

            <button class="close-toast text-gray-400 hover:text-gray-600">
                ✕
            </button>
        </div>
    {% endfor %}

</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.toast').forEach((toast) => {

        // Fermeture automatique après 5 secondes
        setTimeout(() => {
            toast.classList.add('opacity-0', 'translate-x-5');

            setTimeout(() => {
                toast.remove();
            }, 300);
        }, 5000);

        // Fermeture manuelle
        toast.querySelector('.close-toast')?.addEventListener('click', () => {
            toast.remove();
        });
    });
});
</script>